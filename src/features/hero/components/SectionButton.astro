---
import { Icon } from "astro-icon/components";

interface Props {
  type: "Profile" | "Works" | "Blogs";
}
const { type } = Astro.props;

const iconMap = {
  Profile: "user",
  Works: "code",
  Blogs: "pen",
} as const;
---

<a class="button" href={`/#${type}`}>
  <Icon name={iconMap[type]} class="icon" />
  <p>{type}</p>
</a>

<style>
  .button {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex: 1;
    gap: 8px;
    padding: 20px 24px;
    border-radius: 16px;
    background: var(--card-bg);
    box-shadow: 0px 4px 16px var(--shadow-color);
    transition: all 0.4s ease;
    font-weight: 600;
    &:hover {
      box-shadow: none;
      cursor: pointer;
    }

    .icon {
      color: var(--accent);
      font-size: 2rem;
    }

    @media (max-width: 480px) {
      flex-direction: row;
      width: 240px;

      .icon {
        font-size: 1.5rem;
      }
    }
  }
</style>
