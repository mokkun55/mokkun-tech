---
import type { GetStaticPaths, Page } from "astro";
import Card from "@/components/Card.astro";
import Section from "@/components/Section.astro";
import PageLayout from "@/layouts/PageLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import Pagination from "@/layouts/components/Pagination.astro";

type Props = {
  page: Page<CollectionEntry<"work">>;
};

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const works = (await getCollection("work", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
  );

  return paginate(works, { pageSize: 6 });
};

const { page } = Astro.props as Props;
---

<PageLayout
  title="Works"
  breadcrumbs={[
    {
      label: "Top",
      href: "/",
    },
    {
      label: "Works",
    },
  ]}
>
  <div class="container">
    <Section title="Works" subText="すべての制作物" />
    <div class="works-list">
      {
        page.data.map((work) => (
          <Card
            type="work"
            img={work.data.thumbnailImage}
            title={work.data.title}
            text={work.data.description}
            tags={work.data.tags}
            id={work.id}
          />
        ))
      }
    </div>

    <Pagination
      prevLink={page.url.prev}
      nextLink={page.url.next}
      currentPageNum={page.currentPage}
      lastPageNum={page.lastPage}
    />
  </div>
</PageLayout>

<style>
  .container {
    gap: 32px;
    margin-bottom: 64px;
  }
  .works-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 24px;
  }
</style>
