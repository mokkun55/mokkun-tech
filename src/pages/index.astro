---
import Hero from "../features/hero/Hero.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="もっくん">
  <Hero />

  <!-- TODO ↓はコンポーネントに切り分ける必要あり -->
  <div class="section" id="Profile">
    <div class="container">
      <h1>Profile</h1>
    </div>
  </div>

  <div class="section" id="Works">
    <div class="container">
      <h1>Works</h1>
    </div>
  </div>

  <div class="section" id="Blogs">
    <div class="container">
      <h1>Blogs</h1>
    </div>
  </div>
</Layout>

<style>
  .section:nth-child(even) {
    background: var(--bg-secondary);
  }
</style>
